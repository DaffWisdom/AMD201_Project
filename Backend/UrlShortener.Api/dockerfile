# Giai đoạn 1: Build ứng dụng
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copy file dự án và restore các gói NuGet
COPY ["UrlShortener.Api.csproj", "./"]
RUN dotnet restore "UrlShortener.Api.csproj"

# Copy toàn bộ mã nguồn và build bản Release
COPY . .
RUN dotnet publish "UrlShortener.Api.csproj" -c Release -o /app/publish

# Giai đoạn 2: Chạy ứng dụng (Runtime)
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

# Thiết lập cổng chạy ứng dụng (Render thường dùng 8080)
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "UrlShortener.Api.dll"]